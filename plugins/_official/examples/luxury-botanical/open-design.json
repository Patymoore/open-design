    "useCase": {
      "query": {
        "en": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bentley — Beyond The Collection</title>\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n<link\n  href=\"https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600&family=Great+Vibes&display=swap\"\n  rel=\"stylesheet\"\n/>\n\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script>\n  tailwind.config = {\n    theme: {\n      extend: {\n        fontFamily: {\n          serif: ['\"Instrument Serif\"', \"serif\"],\n          sans: [\"Manrope\", \"sans-serif\"],\n          script: ['\"Great Vibes\"', \"cursive\"],\n        },\n      },\n    },\n  };\n</script>\n\n<style>\n  *, *::before, *::after { box-sizing: border-box; }\n  html, body { margin: 0; padding: 0; background: #000; }\n  body {\n    font-family: \"Manrope\", ui-sans-serif, system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .orbit-container {\n    position: relative;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .orbit-scaling-container {\n    width: 100%;\n    height: 100%;\n    position: relative;\n  }\n  .orbit-scaling-container--responsive {\n    position: absolute;\n    left: 50%;\n    top: 50%;\n    transform-origin: center center;\n  }\n  .orbit-rotation-wrapper {\n    width: 100%;\n    height: 100%;\n    transform-origin: center center;\n    position: relative;\n  }\n  .orbit-path-svg {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n  .orbit-item {\n    position: absolute;\n    will-change: transform;\n    user-select: none;\n  }\n  .orbit-center-content {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 10;\n  }\n  .orbit-image {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n    border-radius: 50%;\n  }\n\n  @keyframes scrollArrow {\n    0%   { transform: translateY(-6px); opacity: 0; }\n    40%  { opacity: 1; }\n    100% { transform: translateY(10px); opacity: 0; }\n  }\n  .scroll-arrow {\n    animation: scrollArrow 1.6s ease-in-out infinite;\n  }\n</style>\n\n<style>\n  .orbit-image {\n    transition: transform 0.3s;\n    cursor: pointer;\n    pointer-events: auto;\n  }\n  .orbit-image:hover {\n    transform: scale(1.2);\n  }\n\n  .blur-up {\n    opacity: 0;\n    transform: translateY(40px);\n    filter: blur(20px);\n    transition: opacity 1s ease-out, transform 1s ease-out, filter 1s ease-out;\n  }\n  .blur-up.in-view {\n    opacity: 1;\n    transform: translateY(0);\n    filter: blur(0px);\n  }\n</style>\n</head>\n<body>\n\n  <!-- ============================================================\n       Hero: 600vh scroll journey with sticky stage\n       ============================================================ -->\n  <div id=\"scroll-container\" class=\"relative w-full h-[600vh] bg-black\">\n    <div class=\"sticky top-0 w-full h-screen overflow-hidden text-white\">\n\n      <!-- Video background -->\n      <video autoplay loop muted playsinline class=\"absolute inset-0 w-full h-full object-cover z-0\">\n        <source src=\"https://plugin-assets.open-design.ai/plugins/luxury-botanical/hf_20260520_114550_b72cc2b7-2267-4d9e-b19f-f3bb4b0c7084-e5c560.mp4\" type=\"video/mp4\" />\n      </video>\n\n      <!-- Top-left logo text -->\n      <div\n        class=\"absolute z-10 flex flex-col items-start text-left text-black select-none leading-[0.95]\"\n        style=\"top: 120px; left: 96px;\">\n        <div class=\"flex items-baseline\">\n          <span style=\"font-family: 'Instrument Serif', serif; font-size: clamp(32px, 5vw, 64px);\">Beyond</span>\n          <span style=\"font-family: 'Instrument Serif', serif; font-style: italic; font-size: clamp(32px, 5vw, 64px); margin-left: 0.05em;\">The</span>\n        </div>\n        <span style=\"font-family: Manrope, ui-sans-serif, system-ui, sans-serif; font-weight: 400; font-size: clamp(28px, 4.4vw, 56px); letter-spacing: -0.01em; margin-top: 0.05em;\">Collection</span>\n      </div>\n\n      <!-- Scroll hint arrow -->\n      <div\n        class=\"js-scroll-hint absolute z-10 left-1/2 -translate-x-1/2 flex flex-col items-center text-white select-none pointer-events-none\"\n        style=\"bottom: 40px;\">\n        <div class=\"relative w-[20px] h-[34px] overflow-hidden\">\n          <svg\n            class=\"scroll-arrow absolute inset-0\"\n            width=\"20\" height=\"34\" viewBox=\"0 0 20 34\" fill=\"none\"\n            xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n            <path d=\"M10 4 V28 M3 21 L10 28 L17 21\" stroke=\"#ffffff\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </div>\n      </div>\n\n      <!-- Clip-path reveal with orbit -->\n      <div\n        id=\"clip-reveal\"\n        class=\"absolute z-20 flex items-center justify-center overflow-hidden\"\n        style=\"clip-path: ellipse(0% 0% at 50% 50%); transform: rotate(-15deg); width: 150vw; height: 150vh; left: -25vw; top: -25vh;\">\n        <div class=\"absolute inset-0 bg-white\"></div>\n        <div\n          class=\"relative flex flex-col items-center justify-center\"\n          style=\"width: 100vw; height: 100vh; transform: rotate(15deg);\">\n          <div class=\"w-[90vw] max-w-[1200px] aspect-square relative z-0\">\n            <div id=\"orbit-container\" class=\"orbit-container\" style=\"width: 100%; height: auto; aspect-ratio: 1 / 1;\" aria-hidden=\"true\">\n              <div id=\"orbit-scaling\" class=\"orbit-scaling-container orbit-scaling-container--responsive\" style=\"width: 800px; height: 800px;\">\n                <div id=\"orbit-rotation\" class=\"orbit-rotation-wrapper\">\n                  <!-- Orbit items are generated by the script below -->\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Text overlays -->\n      <div class=\"absolute inset-0 z-[60] pointer-events-none\">\n\n        <!-- Center brand text -->\n        <div class=\"absolute top-[48%] left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none z-50\">\n          <div\n            class=\"js-fade flex flex-col items-center whitespace-nowrap pointer-events-auto\"\n            style=\"opacity: 0; -webkit-font-smoothing: antialiased; -webkit-backface-visibility: hidden; transform: translateZ(0);\">\n            <div class=\"flex items-baseline text-black leading-none mb-1\">\n              <span class=\"font-serif text-[45px] md:text-[55px] tracking-tight text-black\">Beyond </span>\n              <span class=\"font-serif text-[45px] md:text-[55px] italic tracking-tight text-black\">The</span>\n            </div>\n            <span class=\"font-sans text-[28px] md:text-[36px] tracking-tight text-black mt-[-5px]\">Collection</span>\n          </div>\n        </div>\n\n        <!-- Top-right info -->\n        <div\n          class=\"js-fade-y absolute top-32 right-[calc(6vw+150px)] md:right-[214px] flex flex-col items-start text-left pointer-events-auto cursor-text\"\n          style=\"opacity: 0;\">\n          <span class=\"font-serif text-[40px] leading-none mb-3 text-black\">2K26</span>\n          <span class=\"font-serif text-[16px] uppercase tracking-widest text-black leading-[20px] text-left\">\n            JOIN AN EXCLUSIVE<br />COMMUNITY\n          </span>\n        </div>\n\n        <!-- Bottom-left number -->\n        <div\n          class=\"js-fade-y absolute bottom-8 left-8 md:bottom-16 md:left-16 flex flex-col items-start text-black pointer-events-auto cursor-text\"\n          style=\"opacity: 0;\">\n          <span class=\"font-serif text-[40px] leading-none mb-1 text-black\">0651</span>\n          <span class=\"font-serif text-[16px] uppercase tracking-widest text-black\">COLLECTION</span>\n        </div>\n\n        <!-- Bottom-right CTA -->\n        <div class=\"absolute bottom-16 right-[6vw] md:right-[10vw] flex flex-col items-start z-10 pointer-events-auto\">\n          <p\n            class=\"js-fade-y font-serif text-[16px] uppercase tracking-widest text-black leading-[20px] mb-6 text-left w-[240px] cursor-text\"\n            style=\"opacity: 0;\">\n            JOIN AN EXCLUSIVE COMMUNITY OF SAILORS. WHETHER YOU CRAVE THE THRILL OF THE OPEN\n          </p>\n          <div\n            class=\"js-fade-y flex gap-0 pointer-events-auto items-center\"\n            style=\"opacity: 0;\">\n            <button class=\"bg-black hover:bg-black/90 transition-colors text-white rounded-[40px] px-8 py-3.5 font-serif tracking-[0.1em] uppercase text-[12px] md:text-[14px] z-10\">\n              BUY COLLECTION\n            </button>\n            <button class=\"bg-black hover:bg-black/90 transition-colors w-[46px] h-[46px] flex items-center justify-center rounded-[50%] text-white -ml-2 z-0\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"ml-1\">\n                <path d=\"M5 12h14M12 5l7 7-7 7\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- Header -->\n      <header\n        class=\"js-scroll-hint absolute top-0 left-0 w-full px-6 md:px-12 py-5 md:py-6 flex justify-between items-center z-[100] pointer-events-none\">\n        <a href=\"#\" class=\"flex items-center gap-3 text-black select-none pointer-events-auto\" aria-label=\"Bentley\">\n          <svg width=\"54\" height=\"40\" viewBox=\"0 0 84 60\" fill=\"none\" aria-hidden=\"true\">\n            <g fill=\"currentColor\">\n              <path d=\"M42 22 C30 22 19 16 4 12 C9 26 18 33 30 33 L42 33 Z\" />\n              <path d=\"M42 22 C54 22 65 16 80 12 C75 26 66 33 54 33 L42 33 Z\" />\n              <path d=\"M34 25 C36 28 39 30 42 30 C45 30 48 28 50 25 L42 22 Z\" opacity=\"0.7\" />\n            </g>\n            <text x=\"42\" y=\"52\" text-anchor=\"middle\" font-family=\"'Instrument Serif', serif\" font-size=\"22\" font-style=\"italic\" fill=\"currentColor\">B</text>\n          </svg>\n          <span style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-weight: 600; font-size: 14px; letter-spacing: 0.42em; text-transform: uppercase;\">Bentley</span>\n        </a>\n\n        <a\n          href=\"#\"\n          class=\"pointer-events-auto inline-flex items-center gap-2 bg-black text-white rounded-full pl-5 pr-2 py-2 hover:bg-black/85 transition-colors\"\n          style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase;\">\n          <span class=\"hidden sm:inline\">Shop the collection</span>\n          <span class=\"sm:hidden\">Shop</span>\n          <span class=\"inline-flex w-7 h-7 items-center justify-center rounded-full bg-white/15\">\n            <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M5 12h14M12 5l7 7-7 7\" />\n            </svg>\n          </span>\n        </a>\n      </header>\n\n    </div>\n  </div>\n\n  <!-- ============================================================\n       StaySection\n       ============================================================ -->\n  <section\n    class=\"relative w-full overflow-hidden\"\n    style=\"min-height: 100vh; background-color: #ffffff;\">\n    <img\n      src=\"https://plugin-assets.open-design.ai/plugins/luxury-botanical/pasted-1779282335552-1_gmztyi-eccf42.webp\"\n      alt=\"\"\n      aria-hidden=\"true\"\n      class=\"absolute inset-x-0 bottom-0 w-full pointer-events-none select-none\"\n      style=\"object-fit: cover; object-position: center bottom;\"\n    />\n\n    <div class=\"relative max-w-[1480px] mx-auto px-8 md:px-16 pt-20 md:pt-24 pb-20 md:pb-24 min-h-screen flex flex-col\" style=\"gap: 32px;\">\n      <div class=\"blur-up\">\n        <div style=\"font-family: 'Instrument Serif', serif; font-size: clamp(60px, 11vw, 160px); line-height: 0.95; letter-spacing: -0.01em; color: #000;\">\n          Stay <span style=\"font-style: italic;\">in</span>\n        </div>\n        <div style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-weight: 400; line-height: 0.95; letter-spacing: -0.02em; color: #000; font-size: 64px;\">\n          the collection\n        </div>\n      </div>\n\n      <div class=\"blur-up max-w-md\" style=\"transition-delay: 0.2s;\">\n        <p class=\"mb-6\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; line-height: 1.55; color: rgba(0,0,0,0.78);\">\n          Editions and invitations from the Bentley fragrance studio, sent twice a season.\n        </p>\n        <form class=\"flex items-center border-b border-black/40 pb-2 gap-3\">\n          <input\n            type=\"email\"\n            placeholder=\"your@email.com\"\n            class=\"bg-transparent flex-1 outline-none\"\n            style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; color: #000;\"\n          />\n          <button type=\"submit\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: #000;\">\n            Subscribe →\n          </button>\n        </form>\n      </div>\n    </div>\n  </section>\n\n  <!-- ============================================================\n       Footer\n       ============================================================ -->\n  <footer class=\"relative w-full text-black overflow-hidden\" style=\"background-color: #f4ecdc;\">\n    <div class=\"relative max-w-[1480px] mx-auto px-8 md:px-16 pt-12 md:pt-14 pb-12\">\n      <div\n        class=\"blur-up grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-10 mb-20 md:mb-24\"\n        style=\"transition-delay: 0.15s;\">\n        <div>\n          <div class=\"mb-5 text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">Discover</div>\n          <ul class=\"space-y-3\">\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">All fragrances</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">The bottle</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Sustainability</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Editions</a></li>\n          </ul>\n        </div>\n        <div>\n          <div class=\"mb-5 text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">Studio</div>\n          <ul class=\"space-y-3\">\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Our story</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Perfumers</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Atelier visits</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Press</a></li>\n          </ul>\n        </div>\n        <div>\n          <div class=\"mb-5 text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">Contact</div>\n          <ul class=\"space-y-3\">\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Boutiques</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Concierge</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Returns</a></li>\n            <li><a href=\"#\" class=\"hover:underline\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 15px; font-weight: 400; color: rgba(0,0,0,0.85);\">Care guide</a></li>\n          </ul>\n        </div>\n\n        <div>\n          <div class=\"mb-5 text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">\n            Newsletter\n          </div>\n          <p class=\"mb-5 text-black/65\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 14px; line-height: 1.5;\">\n            Editions and invitations, sent twice a season.\n          </p>\n          <form class=\"flex items-center border-b border-black/30 pb-2 gap-3\">\n            <input\n              type=\"email\"\n              placeholder=\"your@email.com\"\n              class=\"bg-transparent flex-1 outline-none\"\n              style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 14px; color: #000;\"\n            />\n            <button type=\"submit\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase;\">\n              Subscribe →\n            </button>\n          </form>\n        </div>\n      </div>\n\n      <div\n        class=\"blur-up flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pt-8 border-t border-black/15\"\n        style=\"transition-duration: 0.9s; transition-delay: 0.25s;\">\n        <div class=\"text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">\n          © 2026 Beyond The Collection\n        </div>\n        <div class=\"flex items-center gap-5\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase;\">\n          <a href=\"#\" class=\"hover:underline\">Instagram</a>\n          <span class=\"text-black/30\">·</span>\n          <a href=\"#\" class=\"hover:underline\">TikTok</a>\n          <span class=\"text-black/30\">·</span>\n          <a href=\"#\" class=\"hover:underline\">Spotify</a>\n        </div>\n        <div class=\"text-black/55\" style=\"font-family: Manrope, ui-sans-serif, sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;\">\n          EN · USD\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  <script>\n(function () {\n  /* ============================================================\n     Keyframe interpolation helper (piecewise linear)\n     ============================================================ */\n\n  function interpolate(value, inputs, outputs) {\n    if (value <= inputs[0]) return outputs[0];\n    if (value >= inputs[inputs.length - 1]) return outputs[outputs.length - 1];\n    let i = 1;\n    while (value > inputs[i]) i++;\n    const t = (value - inputs[i - 1]) / (inputs[i] - inputs[i - 1]);\n    return outputs[i - 1] + (outputs[i] - outputs[i - 1]) * t;\n  }\n\n  /* ============================================================\n     OrbitImages\n     ============================================================ */\n\n  function generateEllipsePath(cx, cy, rx, ry) {\n    return `M ${cx - rx} ${cy} A ${rx} ${ry} 0 1 0 ${cx + rx} ${cy} A ${rx} ${ry} 0 1 0 ${cx - rx} ${cy}`;\n  }\n\n  const orbitImagesData = [\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL1996-Beyond_wild_vetiver_Flakon_100ml_300dpi_a55ie5-ad7edb.webp\",\n      title: \"Wild Vetiver\",\n      desc: \"Smoky vetiver wrapped in saffron and leather — a grounded, untamed signature.\"\n    },\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL2156_BEYOND_RADIANT_OSMANTHUS_hoc3up-259f05.webp\",\n      title: \"Radiant Osmanthus\",\n      desc: \"Apricot-tinged osmanthus over soft musks. Quietly luminous, never loud.\"\n    },\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL2157_BEYOND_VIBRANT_HIBISCUS_pgiehq-8c4cbc.webp\",\n      title: \"Vibrant Hibiscus\",\n      desc: \"Bright hibiscus and pink pepper resting on creamy sandalwood.\"\n    },\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL2158_BEYOND_MELLOW_HELIOTROPE_agqych-36c451.webp\",\n      title: \"Mellow Heliotrope\",\n      desc: \"Almond, vanilla and heliotrope petals — a powdery, hushed warmth.\"\n    },\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL2371-BL2372-BL2373-Magnetic-Amber_web_2_dbmtpy-e68423.webp\",\n      title: \"Magnetic Amber\",\n      desc: \"Resinous amber, oud and rich woods. The collection's deepest note.\"\n    },\n    {\n      src: \"https://plugin-assets.open-design.ai/plugins/luxury-botanical/BL2156_BEYOND_RADIANT_OSMANTHUS_1_hlc4v1-572755.webp\",\n      title: \"Crystal Edition\",\n      desc: \"A limited cut of the bottle — etched facets, lavender pour, leather collar.\"\n    }\n  ];\n\n  const TARGET_RADIUS = 650;\n  const BASE_WIDTH = 800;\n  const designCenterX = BASE_WIDTH / 2;\n  const designCenterY = BASE_WIDTH / 2;\n  const FOCAL_POINT = 50;\n\n  const orbitContainerEl = document.getElementById(\"orbit-container\");\n  const orbitScalingEl = document.getElementById(\"orbit-scaling\");\n  const orbitRotationEl = document.getElementById(\"orbit-rotation\");\n\n  // Build orbit items\n  const orbitItems = orbitImagesData.map((entry, index) => {\n    const el = document.createElement(\"div\");\n    el.className = \"orbit-item\";\n    el.style.offsetRotate = \"0deg\";\n    el.style.offsetAnchor = \"center center\";\n    el.style.pointerEvents = \"auto\";\n\n    const inner = document.createElement(\"div\");\n    inner.style.cssText = \"width: 100%; height: 100%; position: relative;\";\n\n    const img = document.createElement(\"img\");\n    img.src = entry.src;\n    img.alt = `Orbiting image ${index + 1}`;\n    img.draggable = false;\n    img.className = \"orbit-image\";\n    inner.appendChild(img);\n\n    const label = document.createElement(\"div\");\n    label.style.cssText = \"position: absolute; left: 115%; top: 50%; transform: translateY(-50%); width: min(360px, 95%); color: #000; opacity: 0; pointer-events: none; font-family: Manrope, ui-sans-serif, system-ui, sans-serif;\";\n    const titleEl = document.createElement(\"div\");\n    titleEl.style.cssText = \"font-family: 'Instrument Serif', serif; font-size: clamp(26px, 3vw, 40px); line-height: 1.05; letter-spacing: -0.01em; margin-bottom: 14px; white-space: normal;\";\n    titleEl.textContent = entry.title;\n    const descEl = document.createElement(\"div\");\n    descEl.style.cssText = \"font-family: Manrope, ui-sans-serif, system-ui, sans-serif; font-weight: 400; font-size: clamp(13px, 1vw, 15px); line-height: 1.5; color: rgba(0,0,0,0.72);\";\n    descEl.textContent = entry.desc;\n    label.appendChild(titleEl);\n    label.appendChild(descEl);\n    inner.appendChild(label);\n\n    el.appendChild(inner);\n    orbitRotationEl.appendChild(el);\n    return { el, inner, label, itemOffset: index / orbitImagesData.length * 100 };\n  });\n\n  // Responsive scaling: fit the 800px design space to the container width\n  function updateOrbitScale() {\n    if (!orbitContainerEl.clientWidth) return;\n    const scale = orbitContainerEl.clientWidth / BASE_WIDTH;\n    orbitScalingEl.style.transform = `translate(-50%, -50%) scale(${scale})`;\n  }\n  updateOrbitScale();\n  new ResizeObserver(updateOrbitScale).observe(orbitContainerEl);\n\n  /* ============================================================\n     Scroll-driven animation loop\n     ============================================================ */\n\n  const scrollContainer = document.getElementById(\"scroll-container\");\n  const clipRevealEl = document.getElementById(\"clip-reveal\");\n  const fadeEls = document.querySelectorAll(\".js-fade\");\n  const fadeYEls = document.querySelectorAll(\".js-fade-y\");\n  const scrollHintEls = document.querySelectorAll(\".js-scroll-hint\");\n\n  function getScrollProgress() {\n    const rect = scrollContainer.getBoundingClientRect();\n    const total = scrollContainer.offsetHeight - window.innerHeight;\n    if (total <= 0) return 0;\n    return Math.min(1, Math.max(0, -rect.top / total));\n  }\n\n  const TEXT_KEYS = [0.03, 0.08, 0.15, 0.22, 0.90, 0.98, 1];\n  const ORBIT_KEYS = [0.15, 0.25, 0.85, 0.95, 1];\n\n  let orbitProgress = 0;\n  let prevScroll = 0;\n  let lastTime = performance.now();\n\n  function frame(now) {\n    const delta = now - lastTime;\n    lastTime = now;\n\n    const pos = getScrollProgress();\n\n    // Orbit progress: scroll-driven through the middle of the journey,\n    // gentle auto-rotation at the edges\n    const scrollDelta = pos - prevScroll;\n    prevScroll = pos;\n    let frameSpeed = 0;\n    if (pos > 0.15 && pos < 0.85) {\n      frameSpeed = scrollDelta * 200;\n    } else {\n      frameSpeed = delta / 1000 * 2.5;\n    }\n    orbitProgress += frameSpeed;\n\n    // Clip-path ellipse reveal\n    const rx = interpolate(pos, [0, 0.08, 1], [0, 55, 55]);\n    const ry = interpolate(pos, [0, 0.08, 1], [0, 55, 55]);\n    clipRevealEl.style.clipPath = `ellipse(${rx}% ${ry}% at 50% 50%)`;\n\n    // Text overlays\n    const textOpacity = interpolate(pos, TEXT_KEYS, [0, 1, 1, 0, 0, 1, 1]);\n    const textBlur = interpolate(pos, TEXT_KEYS, [15, 0, 0, 15, 15, 0, 0]);\n    const yElement = interpolate(pos, TEXT_KEYS, [20, 0, 0, 20, 20, 0, 0]);\n    fadeEls.forEach((el) => {\n      el.style.opacity = textOpacity;\n      el.style.filter = `blur(${textBlur}px)`;\n    });\n    fadeYEls.forEach((el) => {\n      el.style.opacity = textOpacity;\n      el.style.filter = `blur(${textBlur}px)`;\n      el.style.transform = `translateY(${yElement}px)`;\n    });\n\n    // Scroll hint arrow + header\n    const scrollHintOpacity = interpolate(pos, [0, 0.03, 0.08], [1, 1, 0]);\n    scrollHintEls.forEach((el) => {\n      el.style.opacity = scrollHintOpacity;\n    });\n\n    // Orbit keyframes\n    const itemSize = interpolate(pos, ORBIT_KEYS, [80, 360, 360, 80, 80]);\n    const orbitRx = interpolate(pos, ORBIT_KEYS, [330, TARGET_RADIUS, TARGET_RADIUS, 330, 330]);\n    const orbitRy = interpolate(pos, ORBIT_KEYS, [140, TARGET_RADIUS, TARGET_RADIUS, 140, 140]);\n    const orbitRotation = interpolate(pos, ORBIT_KEYS, [-15, 0, 0, -15, -15]);\n    const orbitTx = interpolate(pos, ORBIT_KEYS, [0, -(TARGET_RADIUS + 200), -(TARGET_RADIUS + 200), 0, 0]);\n    const focusStrength = interpolate(pos, ORBIT_KEYS, [0, 1, 1, 0, 0]);\n\n    orbitRotationEl.style.transform = `translateX(${orbitTx}px) rotate(${orbitRotation}deg)`;\n\n    const pathValue = generateEllipsePath(designCenterX, designCenterY, orbitRx, orbitRy);\n    const offsetPath = `path(\"${pathValue}\")`;\n\n    orbitItems.forEach((item) => {\n      const rawPos = ((orbitProgress + item.itemOffset) % 100 + 100) % 100;\n\n      let dist = Math.abs(rawPos - FOCAL_POINT);\n      if (dist > 50) dist = 100 - dist;\n      let targetScale = 1;\n      if (dist < 20) {\n        const ratio = dist / 20;\n        const cosCurve = (Math.cos(ratio * Math.PI) + 1) / 2;\n        targetScale = 0.4 + cosCurve * 0.6;\n      } else {\n        targetScale = 0.4;\n      }\n      const itemScale = 1 - focusStrength * (1 - targetScale);\n\n      item.el.style.width = `${itemSize}px`;\n      item.el.style.height = `${itemSize}px`;\n      item.el.style.offsetPath = offsetPath;\n      item.el.style.offsetDistance = `${rawPos}%`;\n      item.el.style.transform = `scale(${itemScale})`;\n      item.el.style.zIndex = Math.round(itemScale * 100);\n      item.inner.style.transform = `rotate(${-orbitRotation}deg)`;\n      item.label.style.opacity = focusStrength;\n    });\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  /* ============================================================\n     Blur-up reveals on scroll into view (once, 30% visible)\n     ============================================================ */\n\n  const revealObserver = new IntersectionObserver((entries) => {\n    entries.forEach((entry) => {\n      if (entry.isIntersecting) {\n        entry.target.classList.add(\"in-view\");\n        revealObserver.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.3 });\n  document.querySelectorAll(\".blur-up\").forEach((el) => revealObserver.observe(el));\n\n  // Keep newsletter forms inert\n  document.querySelectorAll(\"form\").forEach((form) => {\n    form.addEventListener(\"submit\", (e) => e.preventDefault());\n  });\n})();\n  </script>\n</body>\n</html>\n",
        "zh-CN": "构建一个电影感的奢华香氛落地页（Bentley — Beyond The Collection）：全屏视频英雄区、滚动驱动的椭圆 clip-path 揭示、香水瓶环绕椭圆轨道轮播（焦点处放大并显示标签）、Stay in the collection 订阅区与暖色羊皮纸页脚。完整规格以 en 字段为准。"
